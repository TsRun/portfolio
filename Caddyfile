{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges
	}
}

:{$PORT:80} {
	log {
		format json
	}

	respond /health 200

	# Security headers.
	# CSP notes:
	# - script-src 'unsafe-eval': the DC prototype runtime (support.js) evaluates the page's
	#   <script data-dc-script> logic via new Function. Babel is NOT loaded on this page —
	#   it is only fetched for .jsx/.tsx x-imports, and ours are plain .js. If a .jsx import
	#   is ever added, unpkg.com must be re-added to script-src.
	# - React/ReactDOM are self-hosted under /vendor; Savana demo images under /assets/savana.
	# - Fonts: Google Fonts + jsdelivr (Iosevka) are the only remaining external origins.
	# - frame-ancestors 'self' also neutralizes the runtime's origin-unchecked postMessage
	#   listener (support.js) by preventing hostile embedding.
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data:; connect-src 'self'; media-src 'self'; object-src 'none'; frame-src 'none'; frame-ancestors 'self'; form-action 'self'"
		-Server
	}

	# HTML revalidates on every visit (deploys show immediately); assets cache for an hour.
	@html path / *.html
	header @html Cache-Control "no-cache"

	@static path *.js *.css *.svg *.jpg *.jpeg *.png *.webp *.avif *.woff *.woff2 *.ico
	header @static Cache-Control "public, max-age=3600, stale-while-revalidate=86400"

	root * /app/project

	file_server {
		hide .git .env* .thumbnail .DS_Store *.dc.html
	}

	encode {
		gzip
		zstd
	}

	try_files {path} {path}.html {path}/index.html

	handle_errors {
		rewrite * /{err.status_code}.html
		file_server
	}
}
